<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>내 장바구니 - 4989(사구팔구)</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
</head>
<body class="bg-light" style="font-family: 'Malgun Gothic', sans-serif;">

  <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4 shadow-sm">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/">🛒 4989(사구팔구)</a>
      <a class="btn btn-outline-light btn-sm" href="/"><i class="bi bi-shop"></i> 메인 장터로 이동</a>
    </div>
  </nav>

  <div class="container my-5">
    <div class="p-4 mb-4 bg-white rounded-4 shadow-sm border">
      <h3 class="fw-bold m-0"><i class="bi bi-cart-check-fill text-primary"></i> '<%= user ? user.id : '사용자' %>' 님의 장바구니</h3>
    </div>

    <div class="row g-4">
      <div class="col-lg-8">
        <div class="bg-white rounded-4 p-4 shadow-sm border">
          <% if (!cartItems || cartItems.length === 0) { %>
            <div class="text-center py-5">
              <i class="bi bi-cart-x text-muted" style="font-size: 3rem;"></i>
              <p class="text-muted fs-5 mt-3 mb-0">장바구니가 비어 있습니다.</p>
              <a href="/" class="btn btn-primary btn-sm mt-3">물품 보러가기</a>
            </div>
          <% } else { %>
            <% cartItems.forEach(item => { %>
              <div class="d-flex align-items-center py-3 border-bottom cart-item-row" data-price="<%= item.price %>">
                <img src="<%= item.image %>" class="rounded border" style="width: 90px; height: 90px; object-fit: cover;">
                
                <div class="ms-4 flex-grow-1">
                  <h5 class="fw-bold text-dark mb-1"><%= item.title %></h5>
                  <p class="text-secondary small mb-1">재고: <%= item.maxStock || 1 %>개</p>
                  <p class="text-danger fw-bold m-0 item-total-price">
                    <%= (item.price * (item.quantity || 1)).toLocaleString() %>원
                  </p>
                </div>

                <div class="d-flex align-items-center">
                  <div class="d-flex align-items-center me-3">
                    <input type="number" 
                           name="quantity" 
                           value="<%= item.quantity || 1 %>" 
                           min="1" 
                           max="<%= item.maxStock || 1 %>" 
                           class="form-control form-control-sm product-quantity" 
                           style="width: 70px;"
                           onchange="updateQuantity('<%= item._id %>', this)">
                  </div>

                  <form action="/market/cart/delete" method="POST">
                    <input type="hidden" name="cartId" value="<%= item._id %>">
                    <button type="submit" class="btn btn-sm btn-outline-danger">삭제</button>
                  </form>
                </div>
              </div>
            <% }) %>
          <% } %>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="bg-white rounded-4 p-4 shadow-sm border sticky-top" style="top: 20px;">
          <h5 class="fw-bold text-dark mb-3">결제 예정 금액</h5>
          
          <% if (user) { %>
            <div class="card bg-light p-3 mb-2">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" id="useCredit" onchange="calculatePayment()">
                <label class="form-check-label fw-bold" for="useCredit">
                  크레딧 사용 <span class="text-muted">(보유: <%= user.credit.toLocaleString() %>원)</span>
                </label>
              </div>
            </div>
            <div class="card bg-light p-3 mb-3">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" id="useCash" onchange="calculatePayment()">
                <label class="form-check-label fw-bold" for="useCash">
                  가상 현금 사용 <span class="text-muted">(보유: <%= (user.cash || 0).toLocaleString() %>원)</span>
                </label>
              </div>
            </div>
          <% } %>

          <div class="d-flex justify-content-between mb-2">
            <span>상품 총액:</span>
            <span id="total-price-display">0원</span>
          </div>

          <hr>
          <div class="d-flex justify-content-between align-items-center mb-4">
            <span class="text-dark fw-bold">최종 결제 금액</span>
            <span class="text-danger fw-bold h3 m-0">
              <span id="final-total-price">0</span>원 
            </span>
          </div>

          <form action="/order" method="POST">
            <input type="hidden" name="totalPrice" id="totalPriceInput" value="0">
            <input type="hidden" name="isCreditUsed" id="isCreditUsedInput" value="false">
            <input type="hidden" name="isCashUsed" id="isCashUsedInput" value="false">
            <button type="submit" class="btn btn-primary w-100 btn-lg fw-bold py-3">
              <i class="bi bi-credit-card"></i> 주문하기
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <footer class="text-center py-4 text-muted border-top bg-white mt-5 small">
    &copy; 2026 4989(사구팔구) 이진혁 이서준 문지송 | All Rights Reserved.
  </footer>

  <script>
    window.onload = calculatePayment;

    function updateQuantity(cartId, inputElement) {
      const row = inputElement.closest('.cart-item-row');
      const price = parseInt(row.getAttribute('data-price'));
      const quantity = parseInt(inputElement.value);

      if (quantity < 1) return;

      const itemTotalPriceEl = row.querySelector('.item-total-price');
      itemTotalPriceEl.innerText = (price * quantity).toLocaleString() + '원';

      fetch('/market/cart/update', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ cartId: cartId, quantity: quantity })
      })
      .then(res => { if (!res.ok) alert('수량 업데이트 실패'); })
      .then(() => calculatePayment())
      .catch(err => console.error(err));
    }

    function calculatePayment() {
      let total = 0;
      document.querySelectorAll('.cart-item-row').forEach(row => {
        const price = parseInt(row.getAttribute('data-price'));
        const quantity = parseInt(row.querySelector('.product-quantity').value);
        total += (price * quantity);
      });

      const useCreditCheckbox = document.getElementById('useCredit');
      const useCashCheckbox = document.getElementById('useCash');
      
      document.getElementById('total-price-display').innerText = total.toLocaleString() + '원';
      document.getElementById('final-total-price').innerText = total.toLocaleString();
      
      document.getElementById('totalPriceInput').value = total;
      document.getElementById('isCreditUsedInput').value = (useCreditCheckbox && useCreditCheckbox.checked) ? 'true' : 'false';
      document.getElementById('isCashUsedInput').value = (useCashCheckbox && useCashCheckbox.checked) ? 'true' : 'false';
    }
  </script>
</body>
</html>