<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <title>마이페이지</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <div class="container my-5">
    
    <div class="card p-4 shadow-sm mb-4">
      <h3 class="mb-4">👤 마이페이지</h3>
      <hr>
      <p><strong>아이디:</strong> <%= user.id %></p>
      <p><strong>이름:</strong> <%= user.name %></p>
      <p><strong>보유 크레딧:</strong> <%= (user.credit || 0).toLocaleString() %>원</p>
      <p><strong>보유 가상 현금:</strong> <%= (user.cash || 0).toLocaleString() %>원</p>
    </div>

    <!-- 월별 통계 영역 -->
    <div class="card p-4 shadow-sm mb-4">
      <h4 class="mb-3">📅 월별 이용 통계</h4>
      <form action="/mypage" method="GET" class="row g-3 mb-4 align-items-center">
        <div class="col-auto">
          <input type="month" name="month" class="form-control" value="<%= selectedMonth %>">
        </div>
        <div class="col-auto">
          <button type="submit" class="btn btn-outline-primary">조회하기</button>
        </div>
      </form>

      <div class="row">
        <div class="col-md-4">
          <div class="alert alert-info">
            <strong>이번 달 총 구매 금액:</strong> <%= totalPurchase.toLocaleString() %>원
          </div>
        </div>
        <div class="col-md-4">
          <div class="alert alert-success">
            <strong>판매 수익 (크레딧):</strong> <%= totalSalesCredit.toLocaleString() %>원
          </div>
        </div>
        <div class="col-md-4">
          <div class="alert alert-warning">
            <strong>판매 수익 (가상 현금):</strong> <%= totalSalesCash.toLocaleString() %>원
          </div>
        </div>
      </div>

      <h5 class="mt-3">상품별 판매 수익</h5>
      <table class="table table-sm mt-2">
        <thead class="table-light">
          <tr><th>상품명</th><th>수익</th></tr>
        </thead>
        <tbody>
          <% for (let title in itemRevenueMap) { %>
            <tr>
              <td><%= title %></td>
              <td><%= itemRevenueMap[title].toLocaleString() %>원</td>
            </tr>
          <% } %>
          <% if (Object.keys(itemRevenueMap).length === 0) { %>
            <tr><td colspan="2" class="text-center text-muted">해당 월의 성공한 판매 수익 기록이 없습니다.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <!-- 구매 내역 -->
    <h2 class="mb-3">구매 내역</h2>
    <table class="table bg-white rounded shadow-sm mt-4">
      <thead class="table-light">
        <tr>
          <th>날짜</th>
          <th>구매 상품</th>
          <th>결제 금액</th>
          <th>결제 수단</th> 
          <th>상태</th>
          <th>사유</th>
        </tr>
      </thead>
      <tbody>
        <% if (orders && orders.length > 0) { %>
          <% orders.forEach(order => { %>
            <tr class="<%= order.status === 'fail' ? 'table-danger' : '' %>">
              <td><%= order.createdAt ? order.createdAt.toLocaleDateString() : '날짜정보없음' %></td>
              <td>
                <% if (order.items && order.items.length > 0) { %>
                  <% order.items.forEach(item => { %>
                    <div style="font-size: 0.9rem;">• <%= item.title %> (<%= item.quantity %>개)</div>
                  <% }) %>
                <% } else if (order.productName) { %>
                  <%= order.productName %>
                <% } else { %>
                  <span class="text-muted">내용 없음</span>
                <% } %>
              </td>
              <td><%= (order.totalPrice || 0).toLocaleString() %>원</td>
              <td><%= order.paymentMethod === 'cash' ? '가상 현금' : '크레딧' %></td>
              <td>
                <span class="badge <%= order.status === 'success' ? 'bg-success' : 'bg-danger' %>">
                  <%= order.status === 'success' ? '구매 성공' : '구매 실패' %>
                </span>
              </td>
              <td>
                <%= order.reason || (order.status === 'success' ? '구매 완료' : '잔고 부족') %>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="6" class="text-center text-muted">아직 구매 내역이 없습니다.</td>
          </tr>
        <% } %>
      </tbody>
    </table>

    <!-- 구매 페이지네이션 -->
    <% if (totalOrderPages > 1) { %>
      <%
        const orderBlockSize = 10;
        const orderStartPage = Math.floor((orderPage - 1) / orderBlockSize) * orderBlockSize + 1;
        const orderEndPage = Math.min(orderStartPage + orderBlockSize - 1, totalOrderPages);
      %>
      <nav class="mt-3">
        <ul class="pagination justify-content-center">
          <% if (orderStartPage > 1) { %>
            <li class="page-item">
              <a class="page-link" href="/mypage?orderPage=<%= orderStartPage - 1 %>&salesPage=<%= salesPage %>">이전</a>
            </li>
          <% } %>
          
          <% for(let i = orderStartPage; i <= orderEndPage; i++) { %>
            <li class="page-item <%= orderPage === i ? 'active' : '' %>">
              <a class="page-link" href="/mypage?orderPage=<%= i %>&salesPage=<%= salesPage %>"><%= i %></a>
            </li>
          <% } %>

          <% if (orderEndPage < totalOrderPages) { %>
            <li class="page-item">
              <a class="page-link" href="/mypage?orderPage=<%= orderEndPage + 1 %>&salesPage=<%= salesPage %>">다음</a>
            </li>
          <% } %>
        </ul>
      </nav>
    <% } %>

    <!-- 판매 내역 -->
    <h2 class="mt-5 mb-3">판매 내역</h2>
    <table class="table bg-white rounded shadow-sm">
      <thead class="table-light">
        <tr>
          <th>날짜</th>
          <th>판매 상품</th>
          <th>판매 수익</th>
          <th>결제 수단</th>
          <th>상태</th>
          <th>사유</th>
        </tr>
      </thead>
      <tbody>
        <% if (typeof salesHistory !== 'undefined' && salesHistory.length > 0) { %>
          <% salesHistory.forEach(order => { %>
            <% if (order.items && Array.isArray(order.items)) { %>
              <% order.items.filter(item => item.writer === user.id).forEach(item => { %>
                <tr>
                  <td><%= order.createdAt ? order.createdAt.toLocaleDateString() : '' %></td>
                  <td><%= item.title %> (<%= item.quantity %>개)</td>
                  <td><%= (item.price * item.quantity).toLocaleString() %>원</td>
                  <td><%= order.paymentMethod === 'cash' ? '가상 현금' : '크레딧' %></td>
                  <td>
                    <span class="badge <%= order.status === 'success' ? 'bg-success' : 'bg-danger' %>">
                      <%= order.status === 'success' ? '판매 성공' : '판매 실패' %>
                    </span>
                  </td>
                  <td><%= order.reason %></td>
                </tr>
              <% }) %>
            <% } %>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="6" class="text-center text-muted">판매 내역이 없습니다.</td>
          </tr>
        <% } %>
      </tbody>
    </table>

    <!-- 판매 페이지네이션 -->
    <% if (totalSalesPages > 1) { %>
      <%
        const salesBlockSize = 10;
        const salesStartPage = Math.floor((salesPage - 1) / salesBlockSize) * salesBlockSize + 1;
        const salesEndPage = Math.min(salesStartPage + salesBlockSize - 1, totalSalesPages);
      %>
      <nav class="mt-3">
        <ul class="pagination justify-content-center">
          <% if (salesStartPage > 1) { %>
            <li class="page-item">
              <a class="page-link" href="/mypage?orderPage=<%= orderPage %>&salesPage=<%= salesStartPage - 1 %>">이전</a>
            </li>
          <% } %>

          <% for(let i = salesStartPage; i <= salesEndPage; i++) { %>
            <li class="page-item <%= salesPage === i ? 'active' : '' %>">
              <a class="page-link" href="/mypage?orderPage=<%= orderPage %>&salesPage=<%= i %>"><%= i %></a>
            </li>
          <% } %>

          <% if (salesEndPage < totalSalesPages) { %>
            <li class="page-item">
              <a class="page-link" href="/mypage?orderPage=<%= orderPage %>&salesPage=<%= salesEndPage + 1 %>">다음</a>
            </li>
          <% } %>
        </ul>
      </nav>
    <% } %>
    <div class="bg-white rounded-4 p-4 p-md-5 border border-secondary-subtle mt-4 shadow-sm" style="box-shadow: 0 10px 35px rgba(0, 0, 0, 0.05);">
  <h4 class="fw-bold text-dark mb-4">
    <i class="bi bi-box-seam-fill text-primary"></i> 내가 등록한 물품 관리
    <span class="badge bg-primary ms-1 fs-6"><%= myProducts.length %></span>
  </h4>

  <div class="table-responsive rounded-3 border">
    <table class="table table-hover align-middle mb-0 text-center">
      <thead class="table-dark">
        <tr>
          <th scope="col" style="width: 15%;">이미지</th>
          <th scope="col" style="width: 35%;">물품명</th>
          <th scope="col" style="width: 15%;">판매 가격</th>
          <th scope="col" style="width: 15%;">남은 재고</th>
          <th scope="col" style="width: 20%;">관리</th>
        </tr>
      </thead>
      <tbody>
        <% if (myProducts.length === 0) { %>
          <tr>
            <td colspan="5" class="text-center py-5 text-muted">
              <i class="bi bi-exclamation-circle display-6 d-block mb-2 opacity-50"></i>
              장터에 등록한 물품이 존재하지 않습니다.
            </td>
          </tr>
        <% } else { %>
          <% myProducts.forEach(function(product) { %>
            <tr class="<%= product.stock <= 0 ? 'table-light opacity-75' : '' %>">
              <td>
                <div class="d-flex justify-content-center">
                  <img src="<%= product.image %>" class="rounded border" style="width: 50px; height: 50px; object-fit: contain; background: #fff;" alt="상품">
                </div>
              </td>
              <td class="text-start fw-bold">
                <a href="/product/<%= product._id %>" class="text-decoration-none text-dark hover-primary">
                  <%= product.title %>
                </a>
              </td>
              <td class="text-danger fw-bold">
                <%= product.price.toLocaleString() %>원
              </td>
              <td>
                <% if (product.stock <= 0) { %>
                  <span class="badge bg-secondary">품절</span>
                <% } else { %>
                  <span class="badge bg-success"><%= product.stock %>개 남음</span>
                <% } %>
              </td>
              <td>
                <div class="d-flex justify-content-center gap-1">
                  <a href="/product/<%= product._id %>" class="btn btn-sm btn-outline-secondary fw-bold">
                    <i class="bi bi-eye"></i> 보기
                  </a>
                  <form action="/product/delete/<%= product._id %>" method="POST" onsubmit="return confirm('정말 이 물품을 장터에서 파기(삭제)하시겠습니까?');" style="display: inline;">
                    <button type="submit" class="btn btn-sm btn-danger fw-bold">
                      <i class="bi bi-trash3"></i> 회수
                    </button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

    <a href="/" class="btn btn-primary mt-4">메인으로</a>
  </div>
</body>
</html>